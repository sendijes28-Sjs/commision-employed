# ──────────────────────────────────────────────
# Glory8 Commission System — Environment Variables
# Copy this to .env and fill in real values
# ──────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Auth — IMPORTANT: Generate a strong secret for production:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret

# Database (production only — dev uses SQLite)
DATABASE_URL=postgresql://user:password@db:5432/commission_db
DATABASE_SSL=false

# OpenRouter AI API Key (for OCR feature)
OPENROUTER_API_KEY=CHANGE_ME_your_openrouter_api_key_here

# CORS — comma-separated list of allowed origins
# Leave empty or "*" for development, set to actual domain in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4000
